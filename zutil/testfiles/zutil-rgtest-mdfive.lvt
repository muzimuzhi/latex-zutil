\input{zutil-regression-test}
\documentclass{minimal}

% \usepackage[presets=none]{zutil}

\ExplSyntaxOn

\debug_on:n { all }
\debug_off:n { log-functions }

\START

\str_const:Nn \c_test_mdfive_expected_str { 9E1F7E08B77EFEEB1BEF258E30122985 }
\str_const:Nn \c_test_release_expected_str { 2026-07-20 }

% Moved out of \TEST to avoid a luatex-only log line created by \cctab_select:N
%    \g__cctab_tmpii_cctab=\catcodetable...
% in which the "ii" in "tmpii" stands for the current group level.
% Read in file contents then compute its md5sum, so changes in comments
% (e.g., the copyright line) do not affect the md5sum.
\file_get:nnN { regression-test.tex }
  { \cctab_select:N \c_document_cctab }
  \l_tmpa_tl
\str_const:Ne \c_test_mdfive_actual_str
  { \str_mdfive_hash:e { \exp_not:V \l_tmpa_tl } }

\TEST{Check~md5sum~of~regression-test.tex}{
  \str_if_eq:VVTF \c_test_mdfive_expected_str \c_test_mdfive_actual_str
    {
      \PASSED
    }
    {
      % helper
      \cs_new:Npn \test_extract_date:w #1"#2"#3 \scan_stop: { #2 }
      % Extract current l3build version from `l3build.lua` (the first one
      % found by `kpsewhich'). This respects files in TEXMFHOME, while running
      % `l3build --version' always executes the `l3build.lua` in the
      % TEXMFDIST, which might be outdated if a newer version of `l3build.lua`
      % is installed in other TDS trees like TEXMFHOME.
      % Note: Restricted by `TEXINPUTS.latex` setting in `texmf.cnf`, we
      % cannot directly input `l3build.lua` within LaTeX.
      \sys_get_shell:nnN { kpsewhich~l3build.lua }
        { \cctab_select:N \c_other_cctab }
        \l_tmpa_tl
      \ior_open:Nn \g_tmpa_ior { \l_tmpa_tl }
      \ior_str_map_inline:Nn \g_tmpa_ior
        {
          % loosely match the line `release_date = "<YYYY-MM-DD>"`
          \regex_extract_once:nnNT { \A \cO(release_date) } { #1 } \l_tmpa_seq
            {
              \str_const:Ne \c_test_release_actual_str
                { \test_extract_date:w #1 \scan_stop: }
              \ior_map_break:
            }
        }
      \FAILWITH
        {
          l3build~file~'regression-test.tex'~has~been~modified.~
          The~'zutil-regression-test.tex'~may~be~outdated.
          \iow_newline:
          Expected:~ \c_test_mdfive_expected_str \c_space_tl
          % wrap release like <YYYY-MM-DD> to skip l3build log normalization
          (since~l3build~<\c_test_release_expected_str>)
          \iow_newline:
          Actual:~ \use:n {~} ~ \c_test_mdfive_actual_str \c_space_tl
          (l3build~<\c_test_release_actual_str>)
          \iow_newline:
        }
    }
}

\END
